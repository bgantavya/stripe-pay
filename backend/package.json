    "@types/pg": "^8.20.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "morgan": "^1.10.1",
    "nodemon": "^3.1.14",
    "pg": "^8.20.0",
    "stripe": "^21.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  }
