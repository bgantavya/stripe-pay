  "description": "Invoice Payment API",
  "main": "dist/index.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "nodemon src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "build:frontend": "cd ../frontend && npm install && npm run build && mkdir -p ../backend/frontend && cp -r build ../backend/frontend/",
